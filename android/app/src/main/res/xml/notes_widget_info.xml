<?xml version="1.0" encoding="utf-8"?>
<!--
    Metadata del widget "Notes" (últimas notas del message board).
    Layout de 2x2 celdas mínimo, hasta 4x2. Se muestran hasta 3 notas.
-->
<appwidget-provider xmlns:android="http://schemas.android.com/apk/res/android"
    android:initialLayout="@layout/widget_notes"
    android:minWidth="180dp"
    android:minHeight="110dp"
    android:minResizeWidth="140dp"
    android:minResizeHeight="110dp"
    android:targetCellWidth="4"
    android:targetCellHeight="2"
    android:updatePeriodMillis="3600000"
    android:resizeMode="horizontal|vertical"
    android:widgetCategory="home_screen"
    android:previewLayout="@layout/widget_notes"
    android:description="@string/widget_notes_desc" />
